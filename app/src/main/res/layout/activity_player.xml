<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Background blurred cover -->
    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.15" />

    <!-- Dark overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/overlay_dark" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="48dp">

        <!-- Left: Cover Art -->
        <androidx.cardview.widget.CardView
            android:layout_width="320dp"
            android:layout_height="320dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <ImageView
                android:id="@+id/ivCoverLarge"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_radio" />

        </androidx.cardview.widget.CardView>

        <!-- Right: Info + Controls -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="48dp"
            android:layout_marginLeft="48dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvPlayerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="36sp"
                android:fontFamily="sans-serif-bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPlayerSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="18sp"
                android:layout_marginTop="8dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvPlayerGenre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_blue"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvPlayerFrequency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_purple"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvPlayerDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="12dp"
                android:maxLines="3"
                android:ellipsize="end"
                android:lineSpacingExtra="4dp" />

            <!-- Status -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:layout_marginTop="16dp"
                android:text="Conectando..." />

            <!-- Station counter (e.g. "3 / 22") -->
            <TextView
                android:id="@+id/tvStationCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/accent_purple"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:visibility="gone" />

            <!-- Controls Row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical">

                <!-- Previous button -->
                <ImageButton
                    android:id="@+id/btnPrevious"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/btn_control_round"
                    android:src="@drawable/ic_skip_previous"
                    android:scaleType="center"
                    android:focusable="true"
                    android:defaultFocusHighlightEnabled="false"
                    android:contentDescription="Anterior" />

                <!-- Play/Pause button (larger, center) -->
                <ImageButton
                    android:id="@+id/btnPlayPause"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/btn_control_round"
                    android:src="@drawable/ic_pause"
                    android:scaleType="center"
                    android:focusable="true"
                    android:defaultFocusHighlightEnabled="false"
                    android:contentDescription="@string/play" />

                <!-- Next button -->
                <ImageButton
                    android:id="@+id/btnNext"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/btn_control_round"
                    android:src="@drawable/ic_skip_next"
                    android:scaleType="center"
                    android:focusable="true"
                    android:defaultFocusHighlightEnabled="false"
                    android:contentDescription="Siguiente" />

                <!-- Spacer -->
                <View
                    android:layout_width="24dp"
                    android:layout_height="0dp" />

                <!-- Favorite button -->
                <ImageButton
                    android:id="@+id/btnFavorite"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/btn_control_round"
                    android:src="@drawable/ic_favorite_outline"
                    android:scaleType="center"
                    android:focusable="true"
                    android:defaultFocusHighlightEnabled="false"
                    android:contentDescription="Favorito" />

            </LinearLayout>

            <!-- Back button hint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Presiona BACK para volver"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:layout_marginTop="16dp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
