<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Header Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:background="#0D0D1F">

        <!-- Logo / App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stream"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="sans-serif-bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TV"
            android:textColor="@color/accent_blue"
            android:textSize="22sp"
            android:fontFamily="sans-serif-bold" />

        <TextView
            android:id="@+id/tvHeaderInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:layout_marginStart="16dp"
            android:visibility="gone" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Tab: Radios -->
        <TextView
            android:id="@+id/tabRadios"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="Radios en Vivo"
            android:textColor="@color/accent_blue"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/tab_selected_bg"
            android:focusable="true"
            android:clickable="true"
            android:defaultFocusHighlightEnabled="false" />

        <!-- Tab: Demos -->
        <TextView
            android:id="@+id/tabDemos"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="Demos"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/tab_unselected_bg"
            android:focusable="true"
            android:clickable="true"
            android:defaultFocusHighlightEnabled="false" />

        <!-- Tab: Favorites -->
        <TextView
            android:id="@+id/tabFavorites"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="Favoritos"
            android:textColor="@color/text_hint"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/tab_unselected_bg"
            android:focusable="true"
            android:clickable="true"
            android:defaultFocusHighlightEnabled="false" />

    </LinearLayout>

    <!-- Thin accent line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@drawable/bg_gradient" />

    <!-- Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/accent_blue" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="@color/error_red"
            android:textSize="16sp"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Now Playing Bar - clipChildren=false for button scale animations -->
    <LinearLayout
        android:id="@+id/nowPlayingBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#0D0D1F"
        android:visibility="gone"
        android:focusable="true"
        android:clipChildren="false"
        android:clipToPadding="false">

        <ImageView
            android:id="@+id/npCover"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_radio" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/npTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/npSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Equalizer / Live indicator -->
        <TextView
            android:id="@+id/npLiveIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EN VIVO"
            android:textColor="@color/error_red"
            android:textSize="9sp"
            android:fontFamily="sans-serif-bold"
            android:layout_marginEnd="12dp" />

        <!-- Previous button -->
        <ImageButton
            android:id="@+id/npPrev"
            style="@style/StreamTVCircleButton.Small"
            android:src="@drawable/ic_skip_previous"
            android:contentDescription="Anterior" />

        <!-- Play/Pause button -->
        <ImageButton
            android:id="@+id/npPlayPause"
            style="@style/StreamTVCircleButton.Small"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_pause"
            android:contentDescription="@string/play" />

        <!-- Next button -->
        <ImageButton
            android:id="@+id/npNext"
            style="@style/StreamTVCircleButton.Small"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_skip_next"
            android:contentDescription="Siguiente" />

    </LinearLayout>

</LinearLayout>
