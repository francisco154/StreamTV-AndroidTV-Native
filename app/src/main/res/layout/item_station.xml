<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="210dp"
    android:layout_height="260dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    android:focusable="true"
    android:foreground="@drawable/card_bg"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Cover Image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="155dp">

            <ImageView
                android:id="@+id/ivCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_radio"
                android:background="@color/bg_card_focused" />

            <!-- Play overlay on focus -->
            <ImageView
                android:id="@+id/ivPlayOverlay"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play"
                android:visibility="gone"
                android:alpha="0.9" />

            <!-- YouTube overlay -->
            <ImageView
                android:id="@+id/ivYouTubeOverlay"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="6dp"
                android:src="@drawable/ic_music"
                android:visibility="gone" />

            <!-- Genre badge (top-right) -->
            <TextView
                android:id="@+id/tvGenre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_gradient"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Stream type badge (top-left) -->
            <TextView
                android:id="@+id/tvStreamType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:background="#CC000000"
                android:textColor="@color/accent_blue"
                android:textSize="9sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:maxLines="1" />

        </FrameLayout>

        <!-- Station Info -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvFrequency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="3dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
