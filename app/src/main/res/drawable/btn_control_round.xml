<?xml version="1.0" encoding="utf-8"?>
<!-- Round control button with OVAL focus selector (not square!) -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="oval">
            <solid android:color="#2A3B82F6" />
            <stroke android:width="3dp" android:color="@color/accent_blue" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#1A3B82F6" />
            <stroke android:width="2dp" android:color="@color/accent_blue" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF" />
        </shape>
    </item>
</selector>
